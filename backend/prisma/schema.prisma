generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model items {
  id          BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  name        String        @db.VarChar(100)
  category    String        @db.VarChar(20)
  item_type   String?       @db.VarChar(50)
  description String?       @db.Text
  stock       Int           @default(0)
  image_url   String?       @db.Text
  price       Decimal       @db.Decimal(12, 2)
  created_at  DateTime      @default(now()) @db.Timestamp(0)
  transaction transaction[]
}

model users {
  id          BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  username    String        @unique(map: "username") @db.VarChar(50)
  email       String        @unique(map: "email") @db.VarChar(255)
  password    String        @db.VarChar(255)
  role        String        @default("user") @db.VarChar(10)
  created_at  DateTime      @default(now()) @db.Timestamp(0)
  transaction transaction[]
}

model transaction {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId     BigInt   @db.UnsignedBigInt
  itemId     BigInt   @db.UnsignedBigInt
  quantity   Int
  totalPrice Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @db.Timestamp(0)
  items      items    @relation(fields: [itemId], references: [id], onDelete: Cascade, map: "fk_transaction_item")
  users      users    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "fk_transaction_user")

  @@index([itemId], map: "fk_transaction_item")
  @@index([userId], map: "fk_transaction_user")
}
